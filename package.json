{
  "name": "pf-control-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "ts-node --project tsconfig.json prisma/seed.ts",
    "db:setup": "npm run db:generate && npm run db:migrate && npm run db:seed",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "cleanup:smoke:data": "node scripts/cleanup-smoke-data.js",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-vps.ps1",
    "setup:db:vps": "powershell -ExecutionPolicy Bypass -File scripts/setup-postgres-vps.ps1",
    "rollback:vps": "powershell -ExecutionPolicy Bypass -File scripts/rollback-vps.ps1",
    "restore:dock": "powershell -ExecutionPolicy Bypass -File scripts/restore-dock-style.ps1",
    "restore:full": "powershell -ExecutionPolicy Bypass -File scripts/restore-full-to-tag.ps1",
    "server:start": "npx pm2 start ecosystem.config.cjs --env production",
    "server:restart": "npx pm2 restart pf-control-web",
    "server:stop": "npx pm2 stop pf-control-web",
    "server:delete": "npx pm2 delete pf-control-web",
    "server:status": "npx pm2 status",
    "server:logs": "npx pm2 logs pf-control-web",
    "smoke:login:guard": "node scripts/smoke-login-guard.js",
    "smoke:login:admin": "node scripts/smoke-login-admin.js",
    "smoke:dock:no-reload": "node scripts/smoke-dock-no-reload.js",
    "smoke:sidebar:order": "node scripts/smoke-sidebar-order-stability.js",
    "smoke:clientes:visual": "node scripts/smoke-clientes-visual.js",
    "smoke:mail:guard": "node scripts/smoke-mail-guard.js",
    "smoke:password:one-time": "node scripts/smoke-password-one-time.js",
    "smoke:runtime:db": "node scripts/smoke-runtime-db.js",
    "smoke:admin:usuarios:redirect": "node scripts/smoke-admin-usuarios-redirect.js",
    "smoke:ux:permisos": "node scripts/smoke-ux-colaborador-permisos.js",
    "smoke:whatsapp": "node scripts/smoke-whatsapp.js",
    "smoke:whatsapp:admin-ui": "node scripts/smoke-whatsapp-admin-ui.js",
    "smoke:whatsapp:failure-alert": "node scripts/smoke-whatsapp-failure-alert.js",
    "smoke:sesiones:ai": "node scripts/smoke-sesiones-ai.js",
    "guard:interaction-lock": "node scripts/guard-interaction-lock.js",
    "report:whatsapp:phones": "node scripts/report-whatsapp-missing-phones.js",
    "whatsapp:automation:run": "node scripts/run-whatsapp-automation.js",
    "whatsapp:automation:dry": "node scripts/run-whatsapp-automation.js --dry-run",
    "whatsapp:automation:cron:setup": "node scripts/setup-whatsapp-runner-cron.js",
    "smoke:full": "node scripts/smoke-full.js",
    "smoke:auth:mail:all": "node scripts/smoke-auth-mail-all.js",
    "server:save": "npx pm2 save",
    "test:nutrition": "tsx scripts/test-nutrition-calculations.ts",
    "test:nutrition:flow": "tsx scripts/test-nutrition-flow.ts",
    "test:nutrition:all": "npm run test:nutrition && npm run test:nutrition:flow"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^2.4.3",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "postcss": "^8.5.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "pm2": "^5.4.3",
    "prisma": "^6.16.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
