# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local emulator artifacts and workspace bundles
emulator-*.png
emulator-*.xml
pf-control-web-workspace-completo-*.zip

# env files (can opt-in for committing if needed)
.env*
*.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Datos persistentes en tiempo de ejecucion — nunca commitear ni deployar
data/sync-store.json
storage/sync-store.json
/storage/*.json

# Base de datos SQLite en vivo — nunca commitear ni deployar.
# Si se trackea, un `git reset --hard` en el VPS sobrescribe los datos reales.
prisma/dev.db
prisma/dev.db-wal
prisma/dev.db-shm
prisma/dev.db.*
