{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REEMPLAZAR_CON_TU_APPLE_ID",
        "ascAppId": "REEMPLAZAR_CON_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REEMPLAZAR_CON_TU_TEAM_ID"
      }
    }
  }
}
