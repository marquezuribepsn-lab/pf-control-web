model AlumnoAsignado {
  id            String   @id @default(cuid())
  colaborador   User    @relation("ColaboradorAsignado", fields: [colaboradorId], references: [id], onDelete: Cascade)
  colaboradorId String
  alumno        User    @relation("AlumnoAsignado", fields: [alumnoId], references: [id], onDelete: Cascade)
  alumnoId      String
  puedeEditar   Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SyncEntry {
  key       String   @id
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sync_entries")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  COLABORADOR
  CLIENTE
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  role          UserRole @default(CLIENTE)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
    etiquetas     Etiqueta[]
  updatedAt     DateTime @updatedAt

  // Datos personales
  nombreCompleto String @default("Sin nombre")
  edad           Int @default(0)
  fechaNacimiento DateTime @default("2000-01-01T00:00:00.000Z")
  altura         Float @default(0.0)
  telefono       String?
  direccion      String?

  // Permisos
  puedeEditarRegistros   Boolean @default(false)
  puedeEditarPlanes      Boolean @default(false)
  puedeVerTodosAlumnos   Boolean @default(false)
  permisosGranulares     Json? // Permisos específicos por colaborador

  estado                 String @default("activo") // activo, suspendido, baja
  lastLoginAt            DateTime?
  notasInternas          String?  // solo visible para SUPERADMIN

  // Relación con alumnos
  colaboraciones         AlumnoAsignado[] @relation("ColaboradorAsignado")
  asignaciones           AlumnoAsignado[] @relation("AlumnoAsignado")

  // Suscripción del profesor (solo ADMIN)
  subscription           ProfesorSubscription? @relation("ProfesorSuscripcion")

  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

  model Etiqueta {
    id        String   @id @default(cuid())
    texto     String
    color     String   // HEX o nombre
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String
    @@map("etiquetas")
  }

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String?

  @@map("password_reset_tokens")
}

model ProfesorSubscription {
  id               String    @id @default(cuid())
  profesorId       String    @unique
  profesor         User      @relation("ProfesorSuscripcion", fields: [profesorId], references: [id], onDelete: Cascade)
  planTipo         String    @default("basico")   // basico, pro, elite
  maxAlumnos       Int       @default(30)
  maxPlanes        Int       @default(5)
  estado           String    @default("trial")    // trial, activo, suspendido, vencido, cancelado
  fechaInicio      DateTime  @default(now())
  fechaVencimiento DateTime?
  moneda           String    @default("USD")
  importe          Float     @default(0)
  periodoDias      Int       @default(30)
  notas            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  pagos            ProfesorPago[]

  @@map("profesor_subscriptions")
}

model ProfesorPago {
  id               String    @id @default(cuid())
  subscriptionId   String
  subscription     ProfesorSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  monto            Float
  moneda           String    @default("USD")
  metodoPago       String    @default("efectivo") // efectivo, transferencia, tarjeta, otro
  fechaPago        DateTime  @default(now())
  periodoDesde     DateTime
  periodoHasta     DateTime
  comprobante      String?
  notas            String?
  createdAt        DateTime  @default(now())

  @@map("profesor_pagos")
}

model AuditLog {
  id            String   @id @default(cuid())
  accion        String
  detalle       String
  profesorEmail String?
  createdAt     DateTime @default(now())

  @@map("audit_logs")
}

model NotificacionLog {
  id             String   @id @default(cuid())
  profesorEmail  String
  profesorNombre String
  tipo           String   // NotifType
  canales        String   // "email" | "whatsapp" | "email,whatsapp"
  emailEnviado   Boolean  @default(false)
  emailError     String?
  waEnviado      Boolean  @default(false)
  waError        String?
  createdAt      DateTime @default(now())

  @@map("notificacion_logs")
}
